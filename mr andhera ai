        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 20px; }
        .card { background: var(--card-bg); border-radius: 10px; padding: 15px; border: 1px solid #333; transition: 0.3s; }
        .card:hover { border-color: var(--primary); transform: translateY(-5px); }
        .card img { width: 100%; border-radius: 8px; }
        .card h3 { margin: 15px 0 10px; color: var(--primary); }
        
        /* Buttons */
        .btn { background: var(--primary); color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block; font-weight: bold; margin-top: 10px; border: none; cursor: pointer; }
        .btn-secondary { background: #444; margin-left: 10px; }
        
        footer { text-align: center; padding: 40px; color: #777; font-size: 0.9rem; }
    </style>
</head>
