        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: var(--dark); color: var(--text); margin: 0; padding: 0; }
        header { background: #000; padding: 20px; text-align: center; border-bottom: 2px solid var(--primary); }
